rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Optimized Admin check
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // --- COLLECTION RULES ---

    // Collection: Users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      // Allow updates for self/admin OR specifically for the auto-analyse KYC start
      allow update: if (isSignedIn() && (isOwner(userId) || isAdmin())) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['idStatus', 'kycReminderStartedAt']));  

      match /notifications/{notifId} {
        allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
    }

    // Collection: Requests
    match /requests/{requestId} {
      // Allow public GET for the auto-analyse API to check status
      allow get: if true; 

      // Standard owners/admins can read.
      // NOTE: Queries MUST include .where("userId", "==", user.uid)
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      // Allow creation for self
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Admin handles processing. User can only update specific verification fields.
      // Or Allow the auto-analyse API to update status & stepAnalysis
      allow update: if isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stepAnalysis', 'status', 'updatedAt'])) ||
        (
          isSignedIn() && 
          resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'paymentVerificationStatus', 
              'paymentSelfieUrl', 
              'paymentVideoUrl', 
              'paymentVerificationSubmittedAt'
          ])
        ); 
    }

    // Collection: Accounts
    match /accounts/{accountId} {
       allow create: if isAdmin();
       allow read: if isSignedIn() && (
         (resource.data.userId == request.auth.uid) || 
         isAdmin()
       );
       allow update: if isSignedIn() && (
         (resource.data.userId == request.auth.uid && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['iban', 'bankName', 'bic', 'ribEmail', 'updatedAt', 'userId'])) ||
         isAdmin()
       );
       allow delete: if isAdmin();
    }

    // Collection: Transfers
    match /transfers/{transferId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending'
      );
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Collection: Chats
    match /chats/{userId} {
      allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
    }
    
    // Collection: Reviews
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }
    
    // Collection: OTPs (Critical Security)
    match /otps/{email} {
      // Allow creation, retrieval, update (for overwrite) and deletion (for cleanup)
      allow create, get, update, delete: if true; 
      allow list: if false; 
    }

    // GLOBAL DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
